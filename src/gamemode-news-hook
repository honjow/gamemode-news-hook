#!/usr/bin/env python3
"""
gamemode-news-hook — Replace Steam Game Mode update cards with community announcements.

Injects JS into Steam's CEF pages via remote debugging protocol to replace
Valve event cards (appid=1675200) with our community group announcements.
"""

import json
import sys
import os
import time
import re
import logging
import urllib.request

SCRIPT_DIR = "/usr/lib/gamemode-news-hook"
sys.path.insert(0, SCRIPT_DIR)

import cef

SK_CLAN = int(os.environ.get("SK_CLAN", 46069703))
SK_CLAN_STEAMID = (1 << 56) | (7 << 52) | SK_CLAN

log = logging.getLogger("gamemode-news-hook")


def setup_logging(debug=False):
    level = logging.DEBUG if debug else logging.INFO
    fmt = "[%(levelname)s] %(message)s"
    logging.basicConfig(level=level, format=fmt, stream=sys.stderr)


def read_js(filename):
    path = os.path.join(SCRIPT_DIR, "js", filename)
    with open(path, "r", encoding="utf-8") as f:
        return f.read()


def fetch_visible_gids():
    """Fetch visible announcement GIDs from community page for filtering."""
    try:
        url = f"https://steamcommunity.com/gid/{SK_CLAN_STEAMID}/announcements"
        html = urllib.request.urlopen(url, timeout=10).read().decode()
        gids = list(set(re.findall(r'detail/(\d{10,})', html)))
        log.info("Visible GIDs: %s", gids)
        return gids
    except Exception as e:
        log.warning("Failed to fetch visible GIDs, skipping filter: %s", e)
        return []


def inject_xhr_hook(ws, visible_gids):
    """Read xhr-hook.js, fill in parameters, inject into SharedJSContext."""
    js = read_js("xhr-hook.js")
    js = js.replace("/*SK_CLAN*/0", str(SK_CLAN))
    js = js.replace("/*VISIBLE_GIDS*/[]", json.dumps(visible_gids))
    result = cef.evaluate(ws, js)
    log.info("XHR hook result: %s", result)
    return result


def inject_observer(ws):
    """Read observer.js, inject into BigPicture page."""
    js = read_js("observer.js")
    result = cef.evaluate(ws, js)
    log.info("Observer result: %s", result)
    return result


def navigate_refresh(ws):
    """Force library -> settings navigation to trigger XHR hook."""
    log.info("Navigating library -> settings...")
    cef.evaluate(ws, "SteamClient.URL.ExecuteSteamURL('steam://open/library')")
    time.sleep(3)
    cef.evaluate(ws, "SteamClient.URL.ExecuteSteamURL('steam://open/settings')")
    time.sleep(3)
    val = cef.evaluate(ws, "JSON.stringify({log: window.__skXhrLog, title: window.__skOurTitle})")
    log.info("Post-navigation state: %s", val)


def main():
    auto = "--auto" in sys.argv
    debug = "--debug" in sys.argv
    setup_logging(debug)

    if auto:
        log.info("Auto mode: waiting for Steam CEF...")
        sjc_path, bp_path = cef.wait_for_pages()
    else:
        log.info("Manual mode: connecting to CEF...")
        try:
            sjc_path, bp_path = cef.get_pages()
        except Exception as e:
            log.error("Cannot connect to CEF at localhost:8080: %s", e)
            sys.exit(1)

    if not sjc_path or not bp_path:
        log.error("Required CEF pages not found (SharedJSContext / BigPicture)")
        sys.exit(1)

    visible_gids = fetch_visible_gids()

    log.info("Injecting XHR hook into SharedJSContext...")
    ws_sjc = cef.connect("localhost", 8080, sjc_path)
    try:
        inject_xhr_hook(ws_sjc, visible_gids)
        if not auto:
            navigate_refresh(ws_sjc)
        else:
            log.info("Auto mode: skipping forced navigation")
    finally:
        ws_sjc.close()

    log.info("Injecting MutationObserver into BigPicture...")
    ws_bp = cef.connect("localhost", 8080, bp_path)
    try:
        inject_observer(ws_bp)
    finally:
        ws_bp.close()

    log.info("Done.")


if __name__ == "__main__":
    main()
