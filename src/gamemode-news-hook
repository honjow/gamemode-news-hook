#!/usr/bin/env python3
"""
gamemode-news-hook — Replace Steam Game Mode update cards with custom announcements.
gamemode-news-hook — 将 Steam 游戏模式（大屏）的更新卡片替换为自定义公告。

Injects JS into Steam's CEF pages via remote debugging protocol to replace
Valve event cards with custom announcements from a repository.
通过 CEF 远程调试向 Steam 页面注入 JavaScript，用仓库中的自定义公告替换 Valve 活动卡片。
"""

import json
import sys
import os
import time
import signal
import logging
import configparser
import urllib.request
import urllib.error

SCRIPT_DIR = "/usr/lib/gamemode-news-hook"
CONFIG_PATH = "/etc/gamemode-news-hook.conf"

sys.path.insert(0, SCRIPT_DIR)

import cef

log = logging.getLogger("gamemode-news-hook")

VERSION = "1.3.1"

DEFAULTS = {
    "target_appid": "1675200",
    "cef_host": "localhost",
    "cef_port": "8080",
    "lang_list": "auto",
    "monitor_interval": "5",
    "repo_refresh_interval": "1800",
}


def load_config():
    """Load config from file, with env var overrides. Returns a dict.
    从配置文件加载设置，环境变量可覆盖；返回字典。"""
    cfg = dict(DEFAULTS)

    parser = configparser.ConfigParser()
    if os.path.exists(CONFIG_PATH):
        parser.read(CONFIG_PATH, encoding="utf-8")
        if parser.has_section("hook"):
            cfg.update(dict(parser.items("hook")))
        log.debug("Loaded config from %s", CONFIG_PATH)

    env_map = {
        "GNHOOK_TARGET_APPID": "target_appid",
        "GNHOOK_CEF_HOST": "cef_host",
        "GNHOOK_CEF_PORT": "cef_port",
        "GNHOOK_LANG_LIST": "lang_list",
        "GNHOOK_MONITOR_INTERVAL": "monitor_interval",
        "GNHOOK_REPO_REFRESH_INTERVAL": "repo_refresh_interval",
    }
    for env_key, cfg_key in env_map.items():
        val = os.environ.get(env_key)
        if val is not None:
            cfg[cfg_key] = val

    cfg["target_appid"] = int(cfg["target_appid"])
    cfg["cef_port"] = int(cfg["cef_port"])
    cfg["monitor_interval"] = int(cfg["monitor_interval"])
    cfg["repo_refresh_interval"] = int(cfg["repo_refresh_interval"])

    cfg["repo_mirrors"] = []
    if parser.has_section("repo_mirrors"):
        for _name, url in parser.items("repo_mirrors"):
            cfg["repo_mirrors"].append(url)
        log.debug("Loaded repo_mirrors: %s", cfg["repo_mirrors"])

    return cfg


def setup_logging(debug=False):
    level = logging.DEBUG if debug else logging.INFO
    fmt = "%(asctime)s [%(levelname)s] %(message)s"
    datefmt = "%Y-%m-%d %H:%M:%S"

    try:
        from systemd.journal import JournalHandler
        handler = JournalHandler(SYSLOG_IDENTIFIER="gamemode-news-hook")
        handler.setFormatter(logging.Formatter("[%(levelname)s] %(message)s"))
        logging.root.addHandler(handler)
        logging.root.setLevel(level)
        return
    except ImportError:
        pass

    logging.basicConfig(level=level, format=fmt, datefmt=datefmt, stream=sys.stderr)


def read_js(filename):
    path = os.path.join(SCRIPT_DIR, "js", filename)
    with open(path, "r", encoding="utf-8") as f:
        return f.read().replace("/*VERSION*/'0.0.0'", f"'{VERSION}'")


def detect_steam_language(cfg, sjc_path):
    """Detect Steam UI language via CEF.
    Returns (lang_name, lang_id) or (None, None) on failure.
    通过 CEF 检测 Steam 界面语言，返回 (语言名, 语言 ID)。"""
    host, port = cfg["cef_host"], cfg["cef_port"]
    try:
        ws = cef.connect(host, port, sjc_path)
        try:
            result = cef.evaluate(ws, """
                (async function() {
                    var lang = await SteamClient.Settings.GetCurrentLanguage();
                    var langs = await SteamClient.Settings.GetAvailableLanguages();
                    var map = {};
                    for (var i = 0; i < langs.length; i++)
                        map[langs[i].strShortName] = langs[i].language;
                    return JSON.stringify({lang: lang, id: map[lang]});
                })()
            """, await_promise=True)
            if result:
                data = json.loads(result)
                lang_id = data.get("id")
                lang_name = data.get("lang")
                if lang_id is not None and lang_name:
                    log.info("Detected Steam language: %s (id=%d)", lang_name, lang_id)
                    return lang_name, lang_id
        finally:
            ws.close()
    except Exception as e:
        log.warning("Failed to detect Steam language: %s", e)
    return None, None


def detect_os_branch(cfg, sjc_path):
    """Detect current OS branch via SteamClient.Updates.
    通过 SteamClient.Updates 检测当前 OS 更新分支。"""
    host, port = cfg["cef_host"], cfg["cef_port"]
    try:
        ws = cef.connect(host, port, sjc_path)
        try:
            result = cef.evaluate(ws, """
                (async function() {
                    var b = await SteamClient.Updates.GetCurrentOSBranch();
                    return b.sRawName || '';
                })()
            """, await_promise=True)
            if result:
                log.info("Detected OS branch: %s", result)
                return result
        finally:
            ws.close()
    except Exception as e:
        log.warning("Failed to detect OS branch: %s", e)
    return ""


def apply_detected_language(cfg, sjc_path):
    """Detect Steam language and update cfg with lang_list and detected_lang_name.
    检测 Steam 语言，更新 cfg 中的 lang_list 和 detected_lang_name。"""
    lang_name, lang_id = detect_steam_language(cfg, sjc_path)
    if lang_name is None:
        cfg["lang_list"] = "0"
        return

    cfg["lang_list"] = str(lang_id) if lang_id == 0 else f"{lang_id}_0"
    cfg["detected_lang_name"] = lang_name
    log.info("lang_list=%s (lang=%s)", cfg["lang_list"], lang_name)


_repo_etags = {}


def fetch_repo_announcements(cfg):
    """Fetch announcements.json from repo mirrors. Returns raw JSON list,
    or None when an ETag-aware mirror reports 304 Not Modified.
    JS side handles filtering and event construction.
    从公告镜像拉取 announcements.json；任一镜像返回 304 时返回 None 表示未变化。"""
    for url in cfg.get("repo_mirrors", []):
        try:
            req = urllib.request.Request(url)
            cached_etag = _repo_etags.get(url)
            if cached_etag:
                req.add_header("If-None-Match", cached_etag)
            with urllib.request.urlopen(req, timeout=15) as resp:
                new_etag = resp.headers.get("ETag")
                if new_etag:
                    _repo_etags[url] = new_etag
                raw = json.loads(resp.read().decode("utf-8"))
                log.info("Fetched announcements from %s: %d entries", url, len(raw))
                return raw
        except urllib.error.HTTPError as e:
            if e.code == 304:
                log.debug("Repo not modified (ETag) from %s", url)
                return None
            log.warning("Mirror failed %s: HTTP %d", url, e.code)
        except Exception as e:
            log.warning("Mirror failed %s: %s", url, e)
    log.error("All repo mirrors failed")
    return []


# JS expression yielding a deterministic signature of __skOurEvents so we can
# cheaply detect in-page refreshes (e.g. triggered by user "Check for updates")
# and propagate the result to the BigPicture context.
# 计算 __skOurEvents 的签名表达式，用于廉价检测页内刷新（如用户手动检查更新），
# 进而把新数据同步到 BigPicture 上下文。
SJC_SIGNATURE_JS = (
    "(function(){"
    "var e=window.__skOurEvents||[];"
    "if(!e.length)return '';"
    "return e.length+':'+e.map(function(x){"
    "return (x.event_name||'')+'|'+((x.announcement_body&&x.announcement_body.body)||'').length;"
    "}).join(';');"
    "})()"
)


def _apply_events_via_cdp(cfg, ws_path, events):
    """Push a parsed events list into one CEF context and invoke window.__skApply.
    向单个 CEF 上下文推送已 parse 的 events 并触发 window.__skApply。"""
    host, port = cfg["cef_host"], cfg["cef_port"]
    events_json = json.dumps(events, ensure_ascii=False)
    js = (
        "(function(){"
        "if(typeof window.__skApply!=='function')"
        "return JSON.stringify({error:'no apply api'});"
        "window.__skApply(" + events_json + ");"
        "return JSON.stringify({applied:" + str(len(events)) + "});"
        "})()"
    )
    ws = cef.connect(host, port, ws_path)
    try:
        return cef.evaluate(ws, js)
    finally:
        ws.close()


def _apply_raw_via_cdp(cfg, ws_path, raw):
    """Push raw repo JSON into one CEF context: re-parse via window.__skParseRepo
    (so per-context lang/branch filtering applies) then invoke window.__skApply.
    向单个 CEF 上下文推送原始 raw JSON：先用 window.__skParseRepo 在该上下文里
    parse（应用各自上下文的 lang/branch 过滤），再触发 window.__skApply。"""
    host, port = cfg["cef_host"], cfg["cef_port"]
    raw_json = json.dumps(raw, ensure_ascii=False)
    js = (
        "(function(){"
        "if(typeof window.__skParseRepo!=='function'||typeof window.__skApply!=='function')"
        "return JSON.stringify({error:'no apply api'});"
        "var events=window.__skParseRepo(" + raw_json + ");"
        "if(!events||!events.length)"
        "return JSON.stringify({applied:0,reason:'parse-empty'});"
        "window.__skApply(events);"
        "return JSON.stringify({applied:events.length});"
        "})()"
    )
    ws = cef.connect(host, port, ws_path)
    try:
        return cef.evaluate(ws, js)
    finally:
        ws.close()


def push_repo_to_both(cfg, sjc_path, bp_path, raw):
    """Push freshly fetched raw repo JSON to both contexts.
    把新拉取到的 raw 公告推到两个上下文。"""
    log.info("Pushing fresh repo (%d entries) to SJC + BP", len(raw))
    try:
        log.info("  SJC apply: %s", _apply_raw_via_cdp(cfg, sjc_path, raw))
    except Exception as e:
        log.warning("SJC apply failed: %s", e)
    try:
        log.info("  BP  apply: %s", _apply_raw_via_cdp(cfg, bp_path, raw))
    except Exception as e:
        log.warning("BP apply failed: %s", e)


def propagate_sjc_to_bp(cfg, sjc_path, bp_path):
    """Read current __skOurEvents from SJC, push it to BP and trigger __skApply.
    Used to bridge in-page refreshes (only SJC sees the partnerevents XHR) over
    to BigPicture so the user-visible cards update too.
    读取 SJC 当前的 __skOurEvents，推到 BP 并触发 __skApply。
    用于桥接页内刷新（partnerevents XHR 只发生在 SJC）到 BigPicture，
    使用户实际看到的卡片同步更新。"""
    host, port = cfg["cef_host"], cfg["cef_port"]
    ws = cef.connect(host, port, sjc_path)
    try:
        ours_json = cef.evaluate(ws, "JSON.stringify(window.__skOurEvents || [])")
    finally:
        ws.close()
    if not ours_json or ours_json == "[]":
        return None
    js = (
        "(function(){"
        "if(typeof window.__skApply!=='function')"
        "return JSON.stringify({error:'no apply api'});"
        "var e=" + ours_json + ";"
        "window.__skApply(e);"
        "return JSON.stringify({applied:e.length});"
        "})()"
    )
    ws = cef.connect(host, port, bp_path)
    try:
        return cef.evaluate(ws, js)
    finally:
        ws.close()


def _build_xhr_hook_js(cfg):
    """Build the parameterized XHR hook JS string.
    构造参数化的 XHR 钩子 JS 字符串。"""
    js = read_js("xhr-hook.js")
    js = js.replace("/*TARGET_APPID*/1675200", str(cfg["target_appid"]))
    js = js.replace("/*LANG_LIST*/'6_0'", f"'{cfg['lang_list']}'")
    js = js.replace("/*CURRENT_BRANCH*/''", f"'{cfg.get('current_branch', '')}'")
    js = js.replace("/*REPO_MIRRORS*/[]", json.dumps(cfg.get("repo_mirrors", [])))
    js = js.replace("/*DETECTED_LANG*/''", f"'{cfg.get('detected_lang_name', '')}'")
    prefetched = cfg.get("prefetched_events")
    if prefetched is not None:
        js = js.replace("/*PREFETCHED_EVENTS*/null", json.dumps(prefetched, ensure_ascii=False))
    return js


def inject(cfg, sjc_path, bp_path, navigate=False):
    """Inject XHR hook and observer into CEF pages.
    向 CEF 页面注入 XHR 钩子与 MutationObserver。"""
    host, port = cfg["cef_host"], cfg["cef_port"]
    xhr_js = _build_xhr_hook_js(cfg)

    log.info("Injecting XHR hook into SharedJSContext...")
    ws_sjc = cef.connect(host, port, sjc_path)
    try:
        result = cef.evaluate(ws_sjc, xhr_js)
        log.info("XHR hook result (SJC): %s", result)
        if navigate:
            log.info("Navigating library -> settings...")
            cef.evaluate(ws_sjc, "SteamClient.URL.ExecuteSteamURL('steam://open/library')")
            time.sleep(3)
            cef.evaluate(ws_sjc, "SteamClient.URL.ExecuteSteamURL('steam://open/settings')")
            time.sleep(3)
            val = cef.evaluate(ws_sjc, "JSON.stringify({log: window.__skXhrLog, title: window.__skOurTitle})")
            log.info("Post-navigation state: %s", val)
    finally:
        ws_sjc.close()

    log.info("Injecting XHR hook + MutationObserver into BigPicture...")
    ws_bp = cef.connect(host, port, bp_path)
    try:
        result = cef.evaluate(ws_bp, xhr_js)
        log.info("XHR hook result (BP): %s", result)
        js = read_js("observer.js")
        result = cef.evaluate(ws_bp, js)
        log.info("Observer result: %s", result)
    finally:
        ws_bp.close()


def monitor_cef(cfg, sjc_path, bp_path):
    """Poll hook liveness, propagate in-page refreshes to BigPicture, and
    perform periodic background fetch of remote announcements.
    Returns when hook is gone, CEF is down, or branch changed (triggers re-inject).
    轮询钩子存活、把 SJC 的页内刷新同步到 BigPicture、定期后台回拉远程公告。
    钩子丢失、CEF 不可达、或分支变更时返回（触发重新注入）。"""
    host, port = cfg["cef_host"], cfg["cef_port"]
    interval = cfg["monitor_interval"]
    refresh_interval = cfg.get("repo_refresh_interval", 1800)
    fail_count = 0
    max_failures = 2
    last_branch = cfg.get("current_branch", "")
    last_sjc_signature = None
    last_repo_fetch = time.time()

    while not _shutdown:
        time.sleep(interval)
        sig = None
        try:
            ws = cef.connect(host, port, sjc_path)
            try:
                val = cef.evaluate(ws, "typeof window.__skGen !== 'undefined' ? 'alive' : 'gone'")
                if val != "alive":
                    log.info("Hook state lost (JS context reset)")
                    return
                if last_branch:
                    branch = cef.evaluate(ws, """
                        (async function() {
                            var b = await SteamClient.Updates.GetCurrentOSBranch();
                            return b.sRawName || '';
                        })()
                    """, await_promise=True)
                    if branch and branch != last_branch:
                        log.info("OS branch changed: %s -> %s, re-injecting",
                                 last_branch, branch)
                        return
                sig = cef.evaluate(ws, SJC_SIGNATURE_JS)
            finally:
                ws.close()
            fail_count = 0
        except Exception as e:
            fail_count += 1
            if fail_count >= max_failures:
                log.info("CEF unreachable after %d attempts: %s", fail_count, e)
                return
            log.debug("Monitor check failed (attempt %d/%d): %s", fail_count, max_failures, e)
            continue

        # Bridge: if SJC's __skOurEvents changed (e.g. user-triggered XHR
        # refresh), propagate the same data to BigPicture so visible cards update.
        # 桥接：若 SJC 的 __skOurEvents 变了（如用户触发的检查更新），
        # 把同样的数据同步到 BigPicture，刷新可见卡片。
        if sig and last_sjc_signature is not None and sig != last_sjc_signature:
            log.info("SJC events updated, propagating to BigPicture")
            try:
                res = propagate_sjc_to_bp(cfg, sjc_path, bp_path)
                log.info("BP propagate result: %s", res)
            except Exception as e:
                log.warning("Propagate to BP failed: %s", e)
        if sig:
            last_sjc_signature = sig

        # Periodic background fetch — covers cases where the user never visits
        # the updates page but remote content has changed.
        # 定时后台回拉 —— 覆盖用户从不进入更新页但远程已变的场景。
        if refresh_interval > 0 and (time.time() - last_repo_fetch) >= refresh_interval:
            last_repo_fetch = time.time()
            try:
                raw = fetch_repo_announcements(cfg)
                if raw is None:
                    log.debug("Repo refresh: not modified")
                elif raw and raw != cfg.get("prefetched_events"):
                    log.info("Repo refresh: content changed (%d entries), pushing", len(raw))
                    cfg["prefetched_events"] = raw
                    push_repo_to_both(cfg, sjc_path, bp_path, raw)
                    last_sjc_signature = None
                else:
                    log.debug("Repo refresh: no content change")
            except Exception as e:
                log.warning("Repo refresh failed: %s", e)


_shutdown = False


def _handle_signal(signum, frame):
    global _shutdown
    log.info("Received signal %d, shutting down...", signum)
    _shutdown = True


def main():
    auto = "--auto" in sys.argv
    debug = "--debug" in sys.argv
    setup_logging(debug)

    signal.signal(signal.SIGTERM, _handle_signal)
    signal.signal(signal.SIGINT, _handle_signal)

    cfg = load_config()
    log.info("Config: target_appid=%d, cef=%s:%d, monitor=%ds, repo_refresh=%ds",
             cfg["target_appid"], cfg["cef_host"], cfg["cef_port"],
             cfg["monitor_interval"], cfg["repo_refresh_interval"])

    if not auto:
        log.info("Manual mode: connecting to CEF...")
        try:
            sjc_path, bp_path = cef.get_pages(cfg["cef_host"], cfg["cef_port"])
        except Exception as e:
            log.error("Cannot connect to CEF at %s:%d: %s", cfg["cef_host"], cfg["cef_port"], e)
            sys.exit(1)
        if not sjc_path or not bp_path:
            log.error("Required CEF pages not found (SharedJSContext / BigPicture)")
            sys.exit(1)
        if cfg["lang_list"] == "auto":
            apply_detected_language(cfg, sjc_path)
        cfg["current_branch"] = detect_os_branch(cfg, sjc_path)
        raw = fetch_repo_announcements(cfg)
        cfg["prefetched_events"] = raw if raw else []
        inject(cfg, sjc_path, bp_path, navigate=True)
        log.info("Done.")
        return

    # Daemon mode
    auto_lang = cfg["lang_list"] == "auto"
    while not _shutdown:
        log.info("Waiting for Steam CEF...")
        sjc_path, bp_path = cef.wait_for_pages(host=cfg["cef_host"], port=cfg["cef_port"])
        if not sjc_path or not bp_path:
            log.warning("CEF wait timed out, retrying...")
            continue

        if auto_lang:
            apply_detected_language(cfg, sjc_path)
        cfg["current_branch"] = detect_os_branch(cfg, sjc_path)
        raw = fetch_repo_announcements(cfg)
        cfg["prefetched_events"] = raw if raw else []

        try:
            inject(cfg, sjc_path, bp_path)
            log.info("Injection complete, monitoring...")
        except Exception as e:
            log.error("Injection failed: %s", e)
            time.sleep(5)
            continue

        monitor_cef(cfg, sjc_path, bp_path)
        if not _shutdown:
            log.info("Hook lost or CEF disconnected, will re-inject")

    log.info("Shutdown complete.")


if __name__ == "__main__":
    main()
